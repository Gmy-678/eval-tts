# 环境标识：test 加载 .env.test，live 加载 .env.live（与 ttsManagementBack 一致）
ENVIRONMENT=test

# 必填：Gemini API Key（ASR 转写 + 打标）
# 可从 Google AI Studio 获取：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# GCP 凭证（BigQuery / GCS），支持相对路径如 ./cred.json
GOOGLE_APPLICATION_CREDENTIALS=./cred.json

# BigQuery
BQ_PROJECT=noiz-430406

# GCS（与 ttsManagementBack 变量名兼容）
BUCKET_NAME=noiz_data
PUBLIC_VOICE_BUCKET_NAME=noiz_voices

# Gemini 模型
GEMINI_TAG_MODEL=gemini-3.0-pro
GEMINI_ASR_MODEL=gemini-3.0-pro

# Postgres（可选）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# POSTGRES_DSN=postgresql://user:pass@host:5432/dbname

# 输出目录
# OUTPUT_DIR=output

# jiwer WER/CER 评估（ASR 转写与 target_text 对齐）
# WER_LANG=en   # num2words 语言: en, zh, ja, es, fr, de, ...
